# =============================================================
# Local development environment variables.
# Copy real values from the Call Analyzer project — same Supabase project.
# NEVER commit this file to git (it is in .gitignore).
# =============================================================

# --- Supabase PUBLIC keys (safe for browser — VITE_ prefix exposes to Vite) ---
# Supabase Dashboard > Settings > API > Project URL  (https://xxxx.supabase.co)
# Supabase Dashboard > Settings > API > anon / public key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase SERVICE ROLE key (server-side only — used by Netlify functions) ---
# Supabase Dashboard > Settings > API > service_role (secret) key
# This key is ONLY read by serverless functions on the server.
# NEVER use a VITE_ prefix here — it must never reach the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- HubSpot API key is NOT stored here ---
# Each user enters their own HubSpot Private App key in the app's
# Configuration page. It is stored per-user in Supabase (hs_user_config)
# and fetched server-side by the Netlify functions — never in env vars.

# --- Nightly job / Google Sheets settings ---
# Shared secret used by scheduled functions when they queue internal background jobs.
INTERNAL_CRON_SECRET=replace-with-a-random-secret

# Preferred for Netlify production: paste the full service account JSON as one line.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional local fallback when running Netlify functions on this machine.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/Users/TinierTim/TBDev/gps_fupm/_reference/skillful-air-294619-2d5fcd0322e6.json
